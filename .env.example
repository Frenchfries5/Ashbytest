# Copy this file to .env.local and fill in the values. .env*.local is gitignored.

# ── Admin gate (inbound postings add/edit/delete) ─────────────────────────────────
# Shared password for the /admin view. The public dashboard stays read-only; the write
# routes (POST/PATCH/DELETE /api/inbound/postings) reject any request without a valid
# admin session cookie. When unset, /admin can't sign anyone in and writes stay locked.
ADMIN_PASSWORD=

# ── Supabase (outbound sourcing data) ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Ashby direct API ─────────────────────────────────────────────────────────────
# Generate in Ashby: Settings → Integrations → API. Requires jobsRead + applicationsRead.
# Server-only — never exposed to the browser. When unset, the Pipeline tab shows a
# "connect Ashby" state and the Ashby Inbound tab falls back to the published Google Sheet.
ASHBY_API_KEY=

# Optional. Scope the "Ashby Inbound" weekly applicant/relevance reconstruction to a single
# evergreen job posting. Leave blank to aggregate applications across all jobs.
ASHBY_INBOUND_JOB_ID=

# ── MeetAlfred (LinkedIn outreach) — EXPERIMENTAL data probe ──────────────────────
# Generate in MeetAlfred: account settings → API Key (a.k.a. "webhook key"). Server-only.
# NOTE: MeetAlfred authenticates by a `webhook_key` QUERY PARAM (not a header), so all calls
# must stay server-side. Endpoints live at https://meetalfred.com/api/integrations/webhook/.
MEETALFRED_API_KEY=
# Optional override for the API base URL (default: https://meetalfred.com/api/integrations/webhook).
MEETALFRED_BASE_URL=
