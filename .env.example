# Copy this file to .env.local and fill in the values. .env*.local is gitignored.

# ── Admin gate (inbound postings add/edit/delete) ─────────────────────────────────
# Shared password for the /admin view. The public dashboard stays read-only; the write
# routes (POST/PATCH/DELETE /api/inbound/postings) reject any request without a valid
# admin session cookie. When unset, /admin can't sign anyone in and writes stay locked.
ADMIN_PASSWORD=

# ── Supabase (outbound sourcing data) ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Ashby direct API ─────────────────────────────────────────────────────────────
# Generate in Ashby: Settings → Integrations → API. Requires jobsRead + applicationsRead.
# Server-only — never exposed to the browser. When unset, the Pipeline tab shows a
# "connect Ashby" state and the Ashby Inbound tab falls back to the published Google Sheet.
ASHBY_API_KEY=

# Optional. Scope the "Ashby Inbound" weekly applicant/relevance reconstruction to a single
# evergreen job posting. Leave blank to aggregate applications across all jobs.
ASHBY_INBOUND_JOB_ID=

# ── MeetAlfred (LinkedIn outreach) — EXPERIMENTAL data probe ──────────────────────
# Generate in MeetAlfred: account settings → API Key (a.k.a. "webhook key"). Server-only.
# NOTE: MeetAlfred authenticates by a `webhook_key` QUERY PARAM (not a header), so all calls
# must stay server-side. Endpoints live at https://meetalfred.com/api/integrations/webhook/.
MEETALFRED_API_KEY=
# Optional override for the API base URL (default: https://meetalfred.com/api/integrations/webhook).
MEETALFRED_BASE_URL=

# ── Microsoft Graph (weekly stakeholder email) ─────────────────────────────────────
# The weekly summary (Fridays 4pm ET, cron /api/email/weekly) sends through M365 via Graph
# sendMail, app-only. In Entra ID: register an app, grant the Mail.Send APPLICATION permission
# with admin consent, and ideally scope it to just the sender mailbox with an Application Access
# Policy. Server-only. The send no-ops with an error until all four are set.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# The mailbox mail is sent from (and the visible From), e.g. reports@coverdash.com. Recipients
# (managed in /admin) are BCC'd.
MS_SENDER=
# Absolute URL of the deployed dashboard, used for the "View the full dashboard" link in the
# weekly email, e.g. https://your-app.vercel.app. Optional — falls back to Vercel's production
# domain when deployed; if neither is set, the link is omitted.
SITE_URL=

# ── Cron protection (shared by the /api/*/sync routes and /api/email/weekly) ───────
# Optional shared secret Vercel Cron sends as `Authorization: Bearer <secret>` (also accepted
# as a `?secret=` query param for manual curls). When unset, cron-triggered GET routes are
# open/unauthenticated — acceptable for an internal tool, but set this before relying on cron
# in production, especially for /api/email/weekly since it sends real email to stakeholders.
CRON_SECRET=
